  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/fast-fifo": "^1.3.0",
    "@types/node": "^22.15.29",
    "esbuild": "^0.27.3",
    "typedoc": "^0.28.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
